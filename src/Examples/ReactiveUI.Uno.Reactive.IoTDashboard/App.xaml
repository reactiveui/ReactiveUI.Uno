<Application
    x:Class="ReactiveUI.Uno.Reactive.IoTDashboard.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="DashboardBackgroundBrush" Color="#FF0F172A" />
            <SolidColorBrush x:Key="DashboardPanelBrush" Color="#FF111827" />
            <SolidColorBrush x:Key="DashboardAccentBrush" Color="#FF22C55E" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
